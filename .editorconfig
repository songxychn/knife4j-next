# =============================================================================
# .editorconfig —— knife4j-next 仓库的跨编辑器基础风格
#
# 目的：
#   让 IntelliJ IDEA / VS Code / WebStorm / Vim 等编辑器在本仓库采用一致的
#   缩进、换行、字符集规则，避免「AI 写 LF、IDE 保存时转成 CRLF」或者
#   「一个人 tab、一个人 2 空格」这类无意义 diff。
#
# 层叠规则说明：
#   本文件置于仓库根目录且未设 `root = true`，因此子项目里已有的
#   `.editorconfig`（例如 `knife4j-vue/`）会继续覆盖根级规则，保持子项目自治。
#
# 注意：
#   - 本文件不强制 Java 代码的大括号风格、方法空行等，那些交给
#     IDE 的 code style / formatter 负责。
#   - 本文件只规范「每一类文件应该怎么保存」，不规范「代码怎么写」。
# =============================================================================

# -----------------------------------------------------------------------------
# 全局默认
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# Java / Kotlin / Groovy —— 4 空格缩进（Java 社区惯例）
# -----------------------------------------------------------------------------
[*.{java,kt,kts,groovy,scala}]
indent_style = space
indent_size = 4

# -----------------------------------------------------------------------------
# Python（如果将来有）
# -----------------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4

# -----------------------------------------------------------------------------
# Go（保持 tab，gofmt 官方风格）
# -----------------------------------------------------------------------------
[*.go]
indent_style = tab

# -----------------------------------------------------------------------------
# Makefile —— 必须 tab，否则 make 报错
# -----------------------------------------------------------------------------
[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab

# -----------------------------------------------------------------------------
# Shell 脚本
# -----------------------------------------------------------------------------
[*.{sh,bash,zsh}]
end_of_line = lf
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# Windows 批处理 / PowerShell —— 保持 CRLF
# -----------------------------------------------------------------------------
[*.{bat,cmd,ps1}]
end_of_line = crlf

# -----------------------------------------------------------------------------
# TypeScript / JavaScript / Vue（与现有两个子项目的风格一致：2 空格）
# -----------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs,vue,svelte}]
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# JSON / YAML / TOML —— 2 空格
# -----------------------------------------------------------------------------
[*.{json,json5,yml,yaml,toml}]
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# XML / HTML / CSS —— 2 空格（Maven pom.xml 等）
# -----------------------------------------------------------------------------
[*.{xml,html,htm,css,scss,less}]
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# Properties / 配置
# -----------------------------------------------------------------------------
[*.properties]
charset = utf-8
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# Markdown —— 末尾空白有语义（两空格 = 换行），不 trim
# -----------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# 二进制 / 生成物：不应用任何规则
# （editorconfig 对这些文件本身就不生效，这里只是显式关闭，做文档用途）
# -----------------------------------------------------------------------------
[*.{png,jpg,jpeg,gif,ico,webp,pdf,zip,tgz,gz,jar,war,class,woff,woff2,ttf,otf,eot}]
insert_final_newline = false
trim_trailing_whitespace = false

