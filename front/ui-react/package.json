    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@types/react-router-dom": "^5.3.3",
    "antd": "^5.7.3",
    "docx": "^9.6.1",
    "dompurify": "^3.0.6",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "idb-keyval": "^6.2.1",
    "knife4j-core": "*",
