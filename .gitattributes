# =============================================================================
# .gitattributes —— knife4j-next 仓库的文件属性配置
#
# 作用：
#   1. 统一行尾符（跨 macOS / Linux / Windows 避免 CRLF↔LF 抖动）
#   2. 显式声明二进制文件，防止 git 误做行尾转换或打印乱码 diff
#   3. 给 `package-lock.json` 设置 merge 策略，减少手动解决冲突
#   4. 校正 GitHub 语言统计（linguist），让 Java 主工程不被历史 Vue 代码
#      和 webjar 产物淹没
#   5. 打发布 zip 时排除 agent / 文档 / CI 等无关目录
#
# 本文件只影响「今后的改动」以及 `git archive` / GitHub 语言统计，
# 不会主动回溯改写历史文件（不跑 `git add --renormalize`）。
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 行尾符（EOL）
# -----------------------------------------------------------------------------
# 默认：让 git 自动识别文本 / 二进制；仓库内统一存 LF
* text=auto eol=lf

# Shell 脚本必须 LF（Windows 下也不许被改成 CRLF，否则 Linux 下跑不起来）
*.sh  text eol=lf

# Windows 批处理脚本必须 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Maven wrapper 脚本（项目里有 mvnw / mvnw.cmd）
mvnw     text eol=lf
mvnw.cmd text eol=crlf

# -----------------------------------------------------------------------------
# 2. 常见源码 / 配置文本文件（显式声明，优先级高于 text=auto）
# -----------------------------------------------------------------------------
*.java       text
*.kt         text
*.groovy     text
*.scala      text

*.ts         text
*.tsx        text
*.js         text
*.jsx        text
*.mjs        text
*.cjs        text
*.vue        text

*.css        text
*.scss       text
*.less       text
*.html       text
*.htm        text

*.json       text
*.json5      text
*.yml        text
*.yaml       text
*.toml       text
*.xml        text
*.properties text
*.conf       text
*.ini        text
*.md         text diff=markdown
*.txt        text

Dockerfile      text
docker-compose.yml text
Caddyfile       text

*.gitignore    text
*.gitattributes text
.editorconfig  text
.nvmrc         text
.npmrc         text

# -----------------------------------------------------------------------------
# 3. 二进制文件（禁用 EOL 转换和文本 diff）
# -----------------------------------------------------------------------------
# 图片
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.bmp  binary
*.webp binary
*.tif  binary
*.tiff binary
*.psd  binary
*.ai   binary

# SVG 是文本，但 diff 噪声大；当文本处理即可（不加规则，让上面 text=auto 处理）

# 字体
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# 压缩 / 归档 / 构件
*.zip binary
*.tar binary
*.tgz binary
*.gz  binary
*.bz2 binary
*.7z  binary
*.rar binary

# Java / JVM 构件
*.jar   binary
*.war   binary
*.ear   binary
*.class binary

# 其他
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.docx  binary
*.doc   binary
*.pptx  binary
*.ppt   binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary

# -----------------------------------------------------------------------------
# 4. 合并策略
# -----------------------------------------------------------------------------
# lockfile 人工解冲突基本没意义；冲突时保留本地版本，重跑 npm install 即可
package-lock.json merge=ours
yarn.lock         merge=ours
pnpm-lock.yaml    merge=ours
bun.lock          merge=ours

# -----------------------------------------------------------------------------
# 5. GitHub 语言统计（linguist）
# -----------------------------------------------------------------------------
# 历史 Vue2 前端：不计入主语言统计
knife4j-vue/**                                linguist-vendored

# 已打包进仓库的 webjar 产物（压缩 JS/CSS/字体等）：视为生成物
knife4j-openapi2-ui/src/main/resources/webjars/**  linguist-generated
knife4j-openapi3-ui/src/main/resources/webjars/**  linguist-generated

# 文档站
docs-site/**   linguist-documentation
knife4j-doc/** linguist-documentation

# 常见 min 产物
*.min.js   linguist-generated
*.min.css  linguist-generated
*.min.html linguist-generated

# -----------------------------------------------------------------------------
# 6. `git archive` 时排除（发布 zip / tar 不包含这些）
# -----------------------------------------------------------------------------
.agent/        export-ignore
.github/       export-ignore
.gitee/        export-ignore
docs-site/     export-ignore
knife4j-doc/   export-ignore
scripts/       export-ignore
backup/        export-ignore
static/        export-ignore

.editorconfig   export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
.nvmrc          export-ignore
AGENTS.md       export-ignore

